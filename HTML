<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Square Interio | Premium Interior Design</title>

    <link rel="stylesheet" href="css/style.css">

    <!-- Font Awesome -->
    <link rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet">
</head>
<body>

<!-- Header -->
<header>
    <div class="container nav-container">
        <div class="logo">
            <h2>Square Interio</h2>
        </div>

        <nav>
            <ul>
                <li><a href="#">Home</a></li>
                <li><a href="#about">About</a></li>
                <li><a href="#services">Services</a></li>
                <li><a href="#projects">Projects</a></li>
                <li><a href="#contact">Contact</a></li>
            </ul>
        </nav>

        <a href="tel:+918409750111" class="call-btn">
            <i class="fa-solid fa-phone"></i> Call Now
        </a>
    </div>
</header>

<!-- Hero Section -->
<section class="hero">
    <div class="hero-content">
        <h1>Transform Your Space Into A Masterpiece</h1>
        <p>
            Luxury Interior Design Solutions For Homes, Offices and Commercial Spaces.
        </p>

        <div class="hero-buttons">
            <a href="#contact" class="btn">Get Free Consultation</a>
            <a href="#projects" class="btn secondary-btn">View Projects</a>
        </div>
    </div>
</section>

<!-- About -->
<section class="about" id="about">
    <div class="container">
        <div class="section-title">
            <h2>About Us</h2>
        </div>

        <div class="about-content">
            <div class="about-image">
                <img src="images/about.jpg" alt="">
            </div>

            <div class="about-text">
                <h3>Designing Elegant Spaces With Creativity</h3>

                <p>
                    Square Interio specializes in creating modern and luxurious interiors
                    that combine beauty, comfort and functionality.
                </p>

                <p>
                    We deliver premium residential and commercial interior solutions
                    tailored to our clients' lifestyles and preferences.
                </p>

                <a href="#contact" class="btn">Contact Us</a>
            </div>
        </div>
    </div>
</section>

<!-- Services -->
<section class="services" id="services">
    <div class="container">

        <div class="section-title">
            <h2>Our Services</h2>
        </div>

        <div class="service-grid">

            <div class="service-card">
                <i class="fa-solid fa-house"></i>
                <h3>Residential Interiors</h3>
            </div>

            <div class="service-card">
                <i class="fa-solid fa-kitchen-set"></i>
                <h3>Modular Kitchen</h3>
            </div>

            <div class="service-card">
                <i class="fa-solid fa-bed"></i>
                <h3>Bedroom Design</h3>
            </div>

            <div class="service-card">
                <i class="fa-solid fa-couch"></i>
                <h3>Living Room Design</h3>
            </div>

            <div class="service-card">
                <i class="fa-solid fa-building"></i>
                <h3>Commercial Interiors</h3>
            </div>

            <div class="service-card">
                <i class="fa-solid fa-briefcase"></i>
                <h3>Office Interiors</h3>
            </div>

        </div>
    </div>
</section>

<!-- Stats -->
<section class="stats">

    <div class="stat-box">
        <h2>500+</h2>
        <p>Happy Clients</p>
    </div>

    <div class="stat-box">
        <h2>250+</h2>
        <p>Projects Completed</p>
    </div>

    <div class="stat-box">
        <h2>10+</h2>
        <p>Years Experience</p>
    </div>

    <div class="stat-box">
        <h2>50+</h2>
        <p>Expert Team</p>
    </div>

</section>

<!-- Projects -->
<section class="projects" id="projects">

    <div class="container">

        <div class="section-title">
            <h2>Latest Projects</h2>
        </div>

        <div class="project-grid">

            <div class="project-card">
                <img src="images/project1.jpg" alt="">
            </div>

            <div class="project-card">
                <img src="images/project2.jpg" alt="">
            </div>

            <div class="project-card">
                <img src="images/project3.jpg" alt="">
            </div>

            <div class="project-card">
                <img src="images/project4.jpg" alt="">
            </div>

            <div class="project-card">
                <img src="images/project5.jpg" alt="">
            </div>

            <div class="project-card">
                <img src="images/project6.jpg" alt="">
            </div>

        </div>

    </div>

</section>

<!-- Testimonials -->
<section class="testimonials">

    <div class="container">

        <div class="section-title">
            <h2>Testimonials</h2>
        </div>

        <div class="testimonial-box">
            <p>
                "Square Interio transformed our home beautifully.
                Highly professional and amazing execution."
            </p>

            <h4>- Happy Client</h4>
        </div>

    </div>

</section>

<!-- Contact -->
<section class="contact" id="contact">

    <div class="container">

        <div class="section-title">
            <h2>Contact Us</h2>
        </div>

        <form>

            <input type="text" placeholder="Your Name" required>

            <input type="email" placeholder="Email Address" required>

            <input type="tel" placeholder="Phone Number">

            <textarea rows="6" placeholder="Your Message"></textarea>

            <button type="submit" class="btn">
                Send Inquiry
            </button>

        </form>

    </div>

</section>

<!-- Footer -->
<footer>

    <h2>Square Interio</h2>

    <p>
        Premium Interior Design Solutions
    </p>

    <div class="footer-contact">

        <p>
            <i class="fa-solid fa-phone"></i>
            +91 84097 50111
        </p>

        <p>
            <i class="fa-solid fa-envelope"></i>
            squareinteriod@gmail.com
        </p>

    </div>

    <p>
        © 2026 Square Interio. All Rights Reserved.
    </p>

</footer>

<!-- WhatsApp Button -->
<a href="https://wa.me/918409750111" class="whatsapp">
    <i class="fa-brands fa-whatsapp"></i>
</a>

<script src="js/script.js"></script>

</body>
</html>
